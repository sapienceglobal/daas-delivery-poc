PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/daas_poc
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0

# Required in production. Generate a long random value (at least 32 characters).
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated browser origins. Native mobile apps do not need an origin entry.
CORS_ORIGINS=http://localhost:3001,http://195.35.20.207:3001
TRUST_PROXY=1

# Keep false only while serving the API over plain HTTP. Use HTTPS and true in production.
COOKIE_SECURE=false

# Demo users/data are disabled by default in production.
SEED_DEMO_DATA=false

# DoorDash Drive API Sandbox Credentials
DOORDASH_DEVELOPER_ID=your_developer_id_here
DOORDASH_KEY_ID=your_key_id_here
DOORDASH_SIGNING_SECRET=your_signing_secret_here

# Store Information (Mocked for pickup location)
PICKUP_BUSINESS_NAME="The Premium Test Store"
PICKUP_ADDRESS="100 Main St, San Francisco, CA 94105"
PICKUP_PHONE_NUMBER="+16505550100"
