# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/daas_poc
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required in production. Generate a long random value (at least 32 characters).
JWT_SECRET=replace_with_a_long_random_secret
# Web clients use the HttpOnly cookie. Set true only for trusted native apps that
# still need a bearer token in the JSON response.
RETURN_AUTH_TOKEN=false

# ── Tenancy ──────────────────────────────────────────────────────────────────
# Only these tenant IDs can be selected through x-tenant-id. Do not provision
# tenants from live requests; seed/migrate tenant databases explicitly.
TENANT_IDS=marketplace,lassi-lounge

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated browser origins. Native mobile apps do not need an origin entry.
CORS_ORIGINS=http://localhost:3001,http://195.35.20.207:3001
TRUST_PROXY=1

# Optional shared secret for trusted non-browser/server-to-server clients.
# Browser bundles cannot keep this confidential; browser requests rely on CORS,
# HttpOnly auth cookies, and route-level authorization.
APP_SECRET=

# ── Cookies ──────────────────────────────────────────────────────────────────
# Keep false only while serving the API over plain HTTP. Use HTTPS and true in production.
COOKIE_SECURE=false

# ── Frontend URL (for email links) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ── Demo Data ────────────────────────────────────────────────────────────────
# Demo users/data are disabled by default in production.
SEED_DEMO_DATA=false

# ── DoorDash Drive API Credentials ──────────────────────────────────────────
DOORDASH_DEVELOPER_ID=your_developer_id_here
DOORDASH_KEY_ID=your_key_id_here
DOORDASH_SIGNING_SECRET=your_signing_secret_here

# ── Store Information (Mocked for pickup location) ──────────────────────────
PICKUP_BUSINESS_NAME="The Premium Test Store"
PICKUP_ADDRESS="100 Main St, San Francisco, CA 94105"
PICKUP_PHONE_NUMBER="+16505550100"

# ── Cloudinary (Image Uploads) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SendGrid (Email) ────────────────────────────────────────────────────────
# Leave blank in development — emails will be logged to console instead.
SENDGRID_API_KEY=
FROM_EMAIL=noreply@restaurant-platform.com
FROM_NAME=Restaurant Commerce Platform

# ── Stripe (Payments) ───────────────────────────────────────────────────────
# Will be configured in Phase 3
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-06-24.dahlia

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
